# Backend API URL
# For local development:
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# For local network (access from other devices):
# NEXT_PUBLIC_API_URL=http://YOUR_IP:8000/api

# For ngrok tunnel (public internet access):
# NEXT_PUBLIC_API_URL=https://your-ngrok-url.ngrok-free.app/api

# Pusher (optional - for realtime features)
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=mt1
